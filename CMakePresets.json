{
    "version": 8,
    "configurePresets": [
        {
            "name": "release",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/${presetName}",
                "CMAKE_BUILD_TYPE": "Debug",
                "AUTOPAS_BUILD_TARGET_DOC": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "release-build",
            "description": "",
            "displayName": "",
            "configurePreset": "release",
            "targets": [
                "md-flexible"
            ]
        }
    ],
    "workflowPresets": [
        {
            "name": "release-workflow",
            "description": "Default workflow for release build",
            "displayName": "release workflow",
            "steps": [
                {
                    "type": "configure",
                    "name": "release"
                },
                {
                    "type": "build",
                    "name": "release-build"
                }
            ]
        }
    ]
}